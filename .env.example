# ═══════════════════════════════════════════════════════════════════════════════
# NEXUS — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# ─── Quick Start ───
# 1. Create a free Supabase project -> copy URL + anon key + service_role key
# 2. Start local Redis -> docker run -d -p 6379:6379 redis:7-alpine
# 3. (Optional) Start Ollama -> ollama pull llama3.2 && ollama pull nomic-embed-text
# 4. Run: npm run migrate && npm run seed
# 5. Run: npm run dev
# ═══════════════════════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────
#  REQUIRED — App won't start without these
# ──────────────────────────────────────────────

# Supabase project URL (e.g. https://your-project.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anonymous/public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key (for admin operations & the AI worker)
SUPABASE_SERVICE_ROLE_KEY=

# ──────────────────────────────────────────────
#  AUTH
# ──────────────────────────────────────────────

# Site URL for auth redirects (default: http://localhost:3000)
# NEXT_PUBLIC_SITE_URL=

# ──────────────────────────────────────────────
#  REDIS — Required for BullMQ job queue
# ──────────────────────────────────────────────

# Redis server hostname (default: localhost)
REDIS_HOST=localhost

# Redis server port (default: 6379)
REDIS_PORT=6379

# Redis auth password (leave blank if none)
# REDIS_PASSWORD=

# Redis database number (default: 0)
# REDIS_DB=0

# Enable TLS for managed Redis providers like Upstash, Redis Cloud
# Set to "true" if using a remote Redis host (auto-detected for non-local hosts)
# REDIS_TLS=true

# Redis connection string (alternative to REDIS_HOST/PORT/PASSWORD)
# Used primarily for Vercel or production deployments
# REDIS_URL=

# ──────────────────────────────────────────────
#  AI PIPELINE — Required for search & embeddings
# ──────────────────────────────────────────────

# Ollama API URL (default: http://localhost:11434)
# Dev: http://localhost:11434
# Prod: https://your-ollama-server:11434
OLLAMA_URL=http://localhost:11434

# ──────────────────────────────────────────────
#  QUEUE & BACKFILL — Optional (defaults shown)
# ──────────────────────────────────────────────

# Cron schedule for backfill scanning (default: */15 * * * *)
# BACKFILL_CRON=*/15 * * * *

# Items per backfill scan batch (default: 200)
# BACKFILL_BATCH=200

# Set to "false" to disable automatic backfill (default: true)
# BACKFILL_ENABLED=true

# Number of AI jobs to process concurrently per worker (default: 2)
# WORKER_CONCURRENCY=2

# Worker polling interval in milliseconds
# WORKER_POLL_INTERVAL=

# AI pipeline batch size — items processed together in batch jobs (default: 3)
# AI_BATCH_SIZE=3

# Embedding vector dimension — matches your Ollama model output (default: 768)
# VECTOR_DIMENSION=768

# ──────────────────────────────────────────────
#  NOTIFICATIONS — Optional for critical alerts
# ──────────────────────────────────────────────

# Slack incoming webhook URL
# SLACK_WEBHOOK_URL=

# Discord webhook URL
# DISCORD_WEBHOOK_URL=

# Resend.com API key for email notifications
# RESEND_API_KEY=

# Alert recipient email address
# ALERT_EMAIL_TO=

# Alert sender email (default: NEXUS Alerts <alerts@nexus.app>)
# ALERT_EMAIL_FROM=

# ──────────────────────────────────────────────
#  POSTGRES — For LISTEN/NOTIFY support
# ──────────────────────────────────────────────

# Full Postgres connection string (e.g. postgresql://user:pass@host:5432/db)
# Required if you want the AI worker to use LISTEN/NOTIFY for real-time item processing
# DATABASE_URL=

# ──────────────────────────────────────────────
#  DEPLOYMENT
# ──────────────────────────────────────────────

# Override URL for notification links and status checks
# NEXUS_URL=

# Redis hostname for status page display (when different from REDIS_HOST)
# NEXT_PUBLIC_REDIS_HOST=

# Set to "standalone" for Docker builds (next.config.js reads this)
# BUILD_TARGET=
