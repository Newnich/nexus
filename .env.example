# ---
# NEXUS - Environment Variables
# Copy this to .env.local and fill in your values
# ---

# === Supabase (Database + Auth) ===
# Required - used by server/client/admin clients and migration scripts.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# === Ollama (AI Pipeline -- Local, Zero-Cost) ===
# Required for embeddings (nomic-embed-text), text generation (llama3.2),
# summarization, tagging, categorization, sentiment analysis, and connection finding.
# Install: https://ollama.com/download
# Then: ollama pull llama3.2 && ollama pull nomic-embed-text
# Default: http://localhost:11434
OLLAMA_URL=http://localhost:11434

# === pgvector (Vector Search -- In-Database, Zero-Cost) ===
# pgvector runs inside your Supabase Postgres database. No separate service needed.
# Enable via Supabase SQL Editor: CREATE EXTENSION IF NOT EXISTS vector;
# See: scripts/migration_pgvector.sql

# === Redis (BullMQ Queue) ===
# Required for AI processing queue, backfill job, and status monitoring.
# Can be local (docker-compose up -d redis) or managed (Upstash, Redis Cloud).
# NEXT_PUBLIC_REDIS_HOST is a public override for the status page display.
# REDIS_TLS enables TLS/SSL (required by Upstash and most managed providers).
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false
NEXT_PUBLIC_REDIS_HOST=

# === Backfill Job (Automated AI Processing) ===
BACKFILL_CRON=*/15 * * * *
BACKFILL_BATCH=200
BACKFILL_ENABLED=true

# === AI Worker ===
WORKER_CONCURRENCY=2

# === Notification Channels ===
# At least one required for critical alert delivery.
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=

# === Email Alerts (via Resend) ===
# Alternative notification channel for critical alerts.
RESEND_API_KEY=re_xxxxxxxxxxxx
ALERT_EMAIL_TO=admin@example.com
ALERT_EMAIL_FROM=NEXUS Alerts <alerts@nexus.app>

# === Database Change Listener ===
DATABASE_URL=postgresql://...

# === Deployment ===
NEXUS_URL=
BUILD_TARGET=
