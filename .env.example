# ---
# NEXUS - Environment Variables
# Copy this to .env.local and fill in your values
# ---

# === Supabase (Database + Auth) ===
# Required - used by server/client/admin clients and migration scripts.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# === Ollama (AI Pipeline — Local, Zero-Cost) ===
# Required - used for embeddings (nomic-embed-text), text generation (llama3.2),
# summarization, tagging, categorization, sentiment analysis, and connection finding.
# Install: https://ollama.com/download
# Then: ollama pull llama3.2 && ollama pull nomic-embed-text
# Optional - defaults to http://localhost:11434
OLLAMA_URL=http://localhost:11434

# === pgvector (Vector Search — In-Database, Zero-Cost) ===
# pgvector runs inside your Supabase Postgres database.
# No separate service needed. Enable via Supabase SQL Editor:
# CREATE EXTENSION IF NOT EXISTS vector;
# See: scripts/migration_pgvector.sql
