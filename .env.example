# NEXUS — Environment Variables
# Copy this to .env.local and fill in your values

# === Supabase (Database + Auth) ===
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# === OpenAI (AI Pipeline) ===
OPENAI_API_KEY=sk-your_openai_api_key
OPENAI_ORGANIZATION_ID=your_org_id (optional)

# === Pinecone (Vector Search) ===
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_ENVIRONMENT=your_pinecone_environment
PINECONE_INDEX_NAME=nexus-vectors

# === Redis (Queues & Caching) ===
REDIS_URL=redis://localhost:6379

# === Storage ===
STORAGE_BUCKET=nexus-files
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=your_s3_access_key
STORAGE_SECRET_KEY=your_s3_secret_key

# === App ===
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=NEXUS
