{
  "name": "nexus",
  "version": "0.1.0",
  "private": true,
  "description": "NEXUS — AI-native Knowledge OS. The last app you'll ever need for information.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "seed": "tsx scripts/seed.ts",
    "migrate": "tsx scripts/migrate.ts",
    "db:reset": "tsx scripts/migrate.ts && tsx scripts/seed.ts",
    "worker": "tsx workers/ai-worker.ts",
    "worker:dev": "tsx watch workers/ai-worker.ts",
    "extension:dev": "cd extension && npm run dev",
    "extension:build": "cd extension && npm run build",
    "prepare": "husky"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.9.0",
    "@sentry/nextjs": "^10.68.0",
    "@supabase/ssr": "^0.12.3",
    "@supabase/supabase-js": "^2.110.8",
    "@types/nprogress": "^0.2.3",
    "@vercel/analytics": "^2.0.1",
    "bullmq": "^5.81.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "date-fns": "^4.1.0",
    "framer-motion": "^11.12.0",
    "ioredis": "^5.4.0",
    "lucide-react": "^0.453.0",
    "nanoid": "^5.0.0",
    "next": "^14.2.0",
    "nprogress": "^0.2.0",
    "pg": "^8.22.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-hot-toast": "^2.4.1",
    "resend": "^6.18.0",
    "sharp": "^0.35.3",
    "tailwind-merge": "^2.5.0",
    "tailwindcss-animate": "^1.0.7",
    "tiktoken": "^1.0.0",
    "zod": "^3.23.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.4",
    "@vitest/coverage-v8": "^4.1.10",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.1.1",
    "postcss": "^8.4.0",
    "prettier": "^3.4.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.10"
  }
}
